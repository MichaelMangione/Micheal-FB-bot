# Copy to .env and fill in values. Secrets should live only in .env (gitignored).

# 2Captcha API key (https://2captcha.com/)
CAPTCHA_API_KEY=

# Facebook login credentials (for auto-login in new tabs)
FB_EMAIL=
FB_PASSWORD=

# Run browser without UI when true
HEADLESS=false

# Facebook group URL to open (must be a group you can post in)
TARGET_GROUP_URL=https://www.facebook.com/groups/your-group-id

# Multiple groups (comma-separated). This overrides TARGET_GROUP_URL if set.
TARGET_GROUP_URLS=https://www.facebook.com/groups/group1,https://www.facebook.com/groups/group2

# Text to post in the group composer (used if posts.json scheduling is disabled)
POST_TEXT=Hello from automation

# Put your images here: project folder "images/" (next to package.json), or set an absolute path.
# One random .jpg / .png / .gif / .webp is attached when this folder has files. Leave empty for text-only.
POST_IMAGE_DIR=./images

# true = fill composer only (no Post). false = click Post when ready.
SKIP_POST=true

# Keeps the browser open until you press Enter in this terminal (so the Facebook dialog stays visible).
WAIT_FOR_ENTER_BEFORE_CLOSE=true

# Milliseconds to wait after typing and after the image so the UI can render before Post / before you close.
PAUSE_AFTER_COMPOSE_MS=5000

# === SCHEDULING OPTIONS (see schedule.json for more) ===
# Set SKIP_POST=false and use posts.json + schedule.json for automated multi-post scheduling.
# Usage:
#   npm start              — Post single POST_TEXT
#   npm run post-one       — Post next message from posts.json
#   npm run daemon         — Post all messages in posts.json with scheduled delays

